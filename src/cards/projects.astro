---
import { Card } from "studiocms:ui/components/card";

import { useTastro } from "@sipc.ink/tastro"
import { getDict } from "../tool/getDict.js";

const { lang } = useTastro(Astro.request)
const dict = await getDict(lang);
const projects = dict.projects ?? {};
const items = projects.items ?? [];
---

<Card style="width: 100%; height: 100%;">
    <h4 slot="header">🛠️ {projects.title}</h4>
    <div style="display: flex; flex-direction: column; gap: 8px; height: 100%;">
        {items.map((project) => (
            <Card style="width: 100%;">
                <h5 slot="header">
                    <a href={project.url} style="color: #ffffff; text-decoration: none;">{project.name}</a>
                </h5>
                <p style="font-size: 13px; color: #a1a1aa; margin: 0; line-height: 1.4;">
                    {project.desc}
                </p>
            </Card>
        ))}
    </div>
</Card>
