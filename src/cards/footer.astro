---
import { Card } from "studiocms:ui/components/card";

import { useTastro } from "@sipc.ink/tastro"
import { getDict } from "../tool/getDict.js";

const { lang } = useTastro(Astro.request)
const dict = await getDict(lang);
const footer = dict.footer ?? {};
---

<Card style="width: 100%">
	<div style="display: flex;align-items: center;justify-content: space-between;color: #808080;" >
		© {new Date().getFullYear()}
		<a href="https://sipc.ink" style="color: inherit; text-decoration: none;" >
			{footer.site}
		</a>
        <a href="https://hyperos.mi.com/font" style="color: #424242; text-decoration: none;" >
            {footer.font}
        </a>
	</div>
    
</Card>
