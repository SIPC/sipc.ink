---
import Profile from "../cards/profile.astro";
import Links from "../cards/links.astro";
import Footer from "../cards/footer.astro";
import About from "../cards/about.astro";
import Time from "../cards/time.astro";
import Skills from "../cards/skills.astro";
import Projects from "../cards/projects.astro";

import { initTastro, useTastro } from "@sipc.ink/tastro"

initTastro({
  defaultLang: "en",
  languages: {
    en: () => import("../i18n/en.json"),
    zh: () => import("../i18n/zh.json"),
  }
})

const { t, lang} = useTastro(Astro.request)
const bgExists = __BG_EXISTS__;

---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <link rel="stylesheet" crossorigin="anonymous" href="https://cdn.jsdelivr.net/npm/misans@4.1.0/lib/Normal/MiSans-Medium.min.css"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{t("profile.name")}</title>
  </head>
<body class:list={{ "bg-on": bgExists }}>
  <main style="min-height: 100vh; width: 100%; display: flex; align-items: center; justify-content: center; padding: 16px;">
    <div class="outer-grid" style="max-width: 730px; width: 100%; display: grid; gap: 8px;">
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <Profile />
        <div style="flex: 1;">
          <Skills />
        </div>
        <Links />
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <div class="inner-grid" style="display: grid; gap: 8px; flex: 1;">

          <div style="display: flex; flex-direction: column; gap: 8px;">
            <div style="flex: 1;">
              <About />
            </div>
            <div>
              <Time />
            </div>
          </div>

          <div style="height: 100%;">
            <Projects />
          </div>
        </div>

        <Footer />
      </div>

    </div>
  </main>
</body>

<style>
  body {
    font-family: 'MiSans', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #0f0f0f;
    color: #ffffff;
    margin: 0;
    padding: 0;
  }
  body.bg-on {
    background-image: url("/bg.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  :global(body.bg-on .sui-card) {
    background-color: rgba(15, 15, 15, 0.6);
    backdrop-filter: blur(10px) saturate(120%);
    -webkit-backdrop-filter: blur(10px) saturate(120%);
    border: none;
  }
  :global(body.bg-on .sui-card.filled) {
    background-color: rgba(15, 15, 15, 0.6);
  }
  .outer-grid {
    grid-template-columns: 1fr;
  }
  .inner-grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .outer-grid {
      grid-template-columns: 1fr 2fr;
    }
    
    .inner-grid {
      grid-template-columns: 1.3fr 1fr;
    }
  }
</style>

<script>
  // TEST
  window.setLang = function (lang) {
    document.cookie = `lang=${lang}; path=/; max-age=31536000`
    location.reload()
  }
</script>

</html>
